@model IEnumerable<EmployeeManagement.Models.Employee>

@{
    ViewData["Title"] = "Employee List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Employee List</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Employee</a>
</div>

<div class="text-center mb-3">
    <form asp-action="Index" method="get" class="d-inline-block w-50">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by name, email, or department..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-success">Search</button>
        </div>
    </form>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>S.No</th>
            <th>@Html.DisplayNameFor(m => m.First().Name)</th>
            <th>@Html.DisplayNameFor(m => m.First().Email)</th>
            <th>@Html.DisplayNameFor(m => m.First().Department)</th>
            <th>@Html.DisplayNameFor(m => m.First().Designation)</th>
            <th>@Html.DisplayNameFor(m => m.First().Salary)</th>
            <th>@Html.DisplayNameFor(m => m.First().Address)</th>
            <th>@Html.DisplayNameFor(m => m.First().City)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
       
        @if (Model != null && Model.Any())
        {
            int i = 1;
            foreach (var item in Model)
            {
                <tr>
                    <td>@(i++)</td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Department</td>
                    <td>@item.Designation</td>
                    <td>@item.Salary</td>
                    <td>@item.Address</td>
                    <td>@item.City</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        @* <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a> *@
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
                
            }
        }
        else
        {
            <tr><td colspan="9" class="text-center text-muted">No employees found.</td></tr>
        }
    </tbody>
</table>

<!-- ✅ Pagination Controls -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
