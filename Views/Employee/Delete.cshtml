@model EmployeeManagement.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<h2 class="mb-3">Delete Employee</h2>

<form asp-action="Deletes" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" disabled class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" disabled class="form-control" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Department" class="form-label"></label>
            <input asp-for="Department" disabled class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Designation" class="form-label"></label>
            <input asp-for="Designation" disabled class="form-control" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Salary" class="form-label"></label>
            <input asp-for="Salary" disabled class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" disabled class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <textarea asp-for="Address" disabled class="form-control" rows="2"></textarea>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        <button type="submit" class="btn btn-danger" onclick="alert('Employee Deleted. Thank you!')">Delete Employee</button>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
